# trust existing completion dump for faster startup
zstyle ':grml:completion:compinit' arguments -C

# download grml config if doesn't exist
if [ ! -f ~/.zsh/grml.zsh ]; then
    echo "<> grml configuration not found"
    echo "<> installing grml zsh configuration"
    curl -L https://git.grml.org/f/grml-etc-core/etc/zsh/zshrc --create-dirs -o ~/.zsh/grml.zsh
fi

# load grml config
. ~/.zsh/grml.zsh

# this in theory makes it so that shell startup is faster
typeset -ga fpath
fpath+=("$HOME/.config/dotfiles/shells/zsh/completions")

function () {
    local completions_dir="$HOME/.config/dotfiles/shells/zsh/completions"
    local completion_file first_line completion_function
    local -a completion_names

    for completion_file in "$completions_dir"/_*(N-.); do
        IFS= read -r first_line < "$completion_file" || continue
        [[ $first_line == '#compdef '* ]] || continue

        completion_function=${completion_file:t}
        completion_names=(${=first_line#\#compdef })
        (( ${#completion_names} )) || continue

        autoload -Uz "$completion_function"
        compdef "$completion_function" "${completion_names[@]}"
    done
}

# prompts
if command -v git > /dev/null 2>&1
then
    # two-line prompt with git integration
    # download if needed
    if [ ! -d ~/.zsh/agkozak-zsh-prompt ]; then
        echo "<> agkozak prompt not found"
        echo "<> loading agkozak zsh prompt"
        git clone https://github.com/agkozak/agkozak-zsh-prompt \
            "$HOME/.zsh/agkozak-zsh-prompt"
    fi
    fpath+=($HOME/.zsh/agkozak-zsh-prompt)

    # options
    AGKOZAK_LEFT_PROMPT_ONLY=1
    AGKOZAK_PROMPT_DIRTRIM=0

    # if in ssh, change looks
    if [ -n "$SSH_CONNECTION" ]
    then
        AGKOZAK_COLORS_USER_HOST=magenta
    fi

    # setup
    autoload -U promptinit
    promptinit
    # actually choose the prompt
    prompt agkozak-zsh-prompt
else
    # fallback, comes with zsh by default
    autoload -U promptinit
    promptinit
    prompt adam2
fi

# globals
local WORK="$HOME/Workspace"
# "main" function, because I do want my local variables to stay local
function () {
    # some variables
    local DOTFILES="$HOME/.config/dotfiles"
    local SHELL_RC="$HOME/.config/zsh/.zshrc"
    local VIM_RC="$HOME/.config/nvim/init.lua"
    export EDITOR="nvim"

    # add ".local/bin" to path for locally installed scripts (like pipx)
    export PATH="$HOME/.local/bin:$PATH"
    # opencode
    export PATH="$HOME/.opencode/bin:$PATH"

    # add Bun-related paths
    export BUN_INSTALL="$HOME/.bun"
    export PATH="$BUN_INSTALL/bin:$PATH"

    # aliases
    alias cddot="cd $DOTFILES"
    alias upd="source $SHELL_RC"
    alias edsh="$EDITOR $SHELL_RC"
    alias edvim="$EDITOR $VIM_RC"

    # if has python3
    if command -v python3 > /dev/null 2>&1; then
        # but doesn't have python command
        if ! command -v python > /dev/null 2>&1; then
            # just add the alias, for the love of god
            alias python="python3"
        fi
    fi

    # activate virtual environment
    alias activate="source .venv/bin/activate"

    # Remove zsh's `zed` function so `zed` runs the editor binary instead.
    if typeset -f zed > /dev/null 2>&1; then
        unfunction zed
    fi
}

# helpers
cdwork() {
    cd $WORK/$argv[1]
}

_cdwork() {
    _directories -W "$WORK"
}

compdef _cdwork cdwork
